# Path to a pre-downloaded GGUF (overrides HF download)
# GGUF_CACHE_DIR=~/.cache/tiny-llm-edge-bench/models

# Groq API key for LLM-as-judge in quality tasks
GROQ_API_KEY=

# Set to 1 to skip power measurement even on macOS
SKIP_POWER_MEASUREMENT=0

# Hugging Face token (for gated repos)
HF_TOKEN=
